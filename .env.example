NEXT_PUBLIC_APP_STAGE=development

# Supabase Auth + PostgreSQL
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=

# Android Capacitor wrapper target. Use the deployed Vercel URL for production.
CAPACITOR_SERVER_URL=

# Optional Microsoft/Azure SSO routing.
# Supabase must have the Azure provider configured in its Auth settings.
# Add comma-separated full emails or domains. Example:
# AZURE_SSO_DOMAINS=caltronsecurity.com
AZURE_SSO_EMAILS=
AZURE_SSO_DOMAINS=

# Server-only integration plugin credentials.
# These must stay in Vercel env vars and must not be exposed with NEXT_PUBLIC_.
SERVICE_TITAN_BASE_URL=
SERVICE_TITAN_TENANT_ID=
SERVICE_TITAN_CLIENT_ID=
SERVICE_TITAN_CLIENT_SECRET=
ADI_BASE_URL=
ADI_ACCOUNT_NUMBER=
ADI_API_KEY=
