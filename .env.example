# Optional Microsoft Entra ID SSO for the current Auth.js runtime
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
AZURE_SSO_EMAILS=
AZURE_SSO_DOMAINS=
